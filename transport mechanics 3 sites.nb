Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"G0RR", "[", 
    RowBox[{"H_", ",", "W_", ",", " ", "\[Omega]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "Smat", "}"}], ",", 
     RowBox[{
      RowBox[{"Smat", "=", 
       RowBox[{"S", "[", 
        RowBox[{"H", ",", "W", ",", "\[Omega]"}], "]"}]}], ";", " ", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"Smat", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "3"}], "]"}], "]"}], "]"}], "^", "2"}], "+", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"Smat", "[", 
          RowBox[{"[", 
           RowBox[{"6", ",", "3"}], "]"}], "]"}], "]"}], "^", "2"}]}]}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GTRR", "[", 
   RowBox[{"G0RR_", ",", "H_", ",", "W_", ",", "T_", ",", "\[Omega]_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "integrand", "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"integrand", "[", "\[CurlyEpsilon]_", "]"}], ":=", 
      RowBox[{
       RowBox[{"G0RR", "[", 
        RowBox[{"H", ",", "W", ",", "\[CurlyEpsilon]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", " ", "T", " ", 
         RowBox[{
          RowBox[{"Cosh", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[CurlyEpsilon]", "-", "\[Omega]"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "T"}], ")"}]}], "]"}], "^", "2"}]}], ")"}]}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"integrand", "[", "\[CurlyEpsilon]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[CurlyEpsilon]", ",", 
         RowBox[{"-", "120"}], ",", "120"}], "}"}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.986808326786747*^9, 3.9868083671345153`*^9}, {
