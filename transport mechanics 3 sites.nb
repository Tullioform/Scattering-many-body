 RowBox[{
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"t1", "=", "10."}], ",", 
       RowBox[{"\[CapitalDelta]1", "=", "10."}], ",", 
       RowBox[{"t2", "=", "30."}], ",", " ", 
       RowBox[{"\[CapitalDelta]2", "=", "30."}], ",", 
       RowBox[{"\[CapitalGamma]L", "=", "1.5"}], ",", 
       RowBox[{"\[CapitalGamma]R", "=", "0.3"}], ",", 
       RowBox[{"T", "=", "3."}], ",", " ", 
